---
import Layout from '../layouts/Layout.astro';

const phases = [
  {
    name: 'Plan',
    description: 'Define the problem, audience, goal, and success criteria before you build anything.',
    detail: 'The output is a Plan Brief — a short written document that answers: what are we solving, who is it for, what does done look like, and what are we not doing. When AI is building, the Plan Brief is its primary instruction. Every ambiguity in it becomes a guess in the output.',
    link: '../docs/phases/plan.md',
  },
  {
    name: 'Build',
    description: 'Execute against the plan. Stay anchored. Update the brief when the build teaches you something.',
    detail: 'Build is structured discovery, not just execution. You will learn things during the build that planning could not reveal. The Build phase ends when the success criteria are met — not when the work feels complete.',
    link: '../docs/phases/build.md',
  },
  {
    name: 'Ship',
    description: 'Put it in the world. In front of real people. Not "ready to ship" — shipped.',
    detail: 'Ship is the act of making something real — taking it out of your draft folder, your private repo, your local environment, and placing it where it will be used, read, or experienced. Until something is shipped, you are operating on assumptions.',
    link: '../docs/phases/ship.md',
  },
];

const gates = [
  {
    name: 'Research',
    when: 'Before Plan',
    description: 'Understand the problem space before committing to a direction. Define a specific question, set a time limit, produce conclusions — not just notes.',
    link: '../docs/gates/research.md',
  },
  {
    name: 'Plan Validation',
    when: 'After Plan, before Build',
    description: 'Verify the plan is sound. Runs as a loop — find gaps, sharpen the brief, validate again — until someone who did not write the plan can execute it and produce the same result.',
    link: '../docs/gates/validate-plan.md',
  },
  {
    name: 'Build Validation',
    when: 'After Build, before Ship',
    description: 'Verify the output works and matches the success criteria from the Plan Brief. A functional check — distinct from Review, which is a holistic judgment call.',
    link: '../docs/gates/validate-build.md',
  },
  {
    name: 'Review',
    when: 'Before and after Ship',
    description: 'Pre-ship: is this actually ready? Post-ship: did it work? Feed what you learned into the next Plan. This is what makes solveOS a cycle, not a line.',
    link: '../docs/gates/review.md',
  },
];

const principles = [
  {
    name: 'Clarity before action',
    body: 'Before execution begins, you must be able to state the problem, who it is for, and what success looks like — in writing. Not perfect clarity. Enough clarity to make the first decision without guessing. The Plan phase creates this foundation. Without it, every subsequent decision is unanchored.',
  },
  {
    name: 'Build to learn',
    body: 'Planning can only take you so far. The act of building reveals constraints, edge cases, and insights that no amount of thinking can surface. Don\'t treat the Build phase as pure execution — treat it as structured discovery.',
  },
  {
    name: 'Reality is the only validator',
    body: 'No plan, build, or opinion tells you if something works. Only putting it in the world does. Shipping is not the end of the process — it is the beginning of knowing. An imperfect thing that is live produces more real information than a perfect thing that isn\'t.',
  },
  {
    name: 'Gates reduce cost, not momentum',
    body: 'Optional gates exist to catch expensive mistakes early, not to create bureaucracy. If a gate is slowing you down more than it\'s protecting you, skip it. Gates should serve the work, not the other way around.',
  },
  {
    name: 'The brief is your compass',
    body: 'The clarity established in Plan doesn\'t maintain itself. Every decision made during Build is an opportunity to drift from the original goal. The Plan Brief is not a starting artifact — it is an active reference. When what you\'re building no longer matches the brief, you either update the brief in writing or course correct. Silent drift is how projects fail.',
  },
];

const aiRows = [
  { phase: 'Plan',     ai: 'Challenge the problem statement, sharpen constraints, rewrite vague goals', human: 'Own the goal, decide what success means, commit to the plan' },
  { phase: 'Research', ai: 'Surface findings, synthesize information, identify gaps', human: 'Decide what question to answer, judge whether findings are sufficient' },
  { phase: 'Build',    ai: 'Produce the output — code, text, designs — given the Plan Brief and reference files', human: 'Decide which approach to take, recognize when output doesn\'t match the goal, update the brief' },
  { phase: 'Validate', ai: 'Check output against criteria, flag gaps', human: 'Decide whether to ship, iterate, or cut scope' },
  { phase: 'Ship',     ai: '—', human: 'Decide that this goes in front of real people — and that it is the right thing to ship' },
  { phase: 'Review',   ai: 'Measure, summarize, surface patterns', human: 'Decide what to learn and what to change in the next cycle' },
];
---

<Layout title="solveOS — A problem-solving framework for builders and makers">

  <!-- ── Nav ──────────────────────────────────────────── -->
  <nav>
    <div class="container nav-inner">
      <a href="/" class="nav-logo">solveOS</a>
      <span class="nav-link nav-coming-soon">Docs <span class="cs-badge">coming soon</span></span>
    </div>
  </nav>

  <!-- ── Section 1: Hero ──────────────────────────────── -->
  <section id="hero" class="hero">
    <div class="container hero-inner">
      <p class="hero-eyebrow">A framework for builders and makers</p>
      <h1 class="hero-title">Plan. Build. Ship.<br />Repeat.</h1>
      <p class="hero-sub">
        A repeatable structure for solving anything — designed from the ground up for AI-first execution.
      </p>

      <div class="loop-diagram">
        <div class="loop-row">
          <span class="loop-top-line"></span>
        </div>
        <div class="loop-main">
          <span class="loop-arrow-left">↓</span>
          <div class="loop-steps">
            <span class="lph">Plan</span>
            <span class="lar">→</span>
            <span class="lph">Build</span>
            <span class="lar">→</span>
            <span class="lph">Ship</span>
            <span class="lar">→</span>
            <span class="lgt">[Review]</span>
          </div>
          <span class="loop-arrow-right">↩</span>
        </div>
        <div class="loop-phase-labels">
          <div class="lpl"><strong>Plan</strong><span>Define the problem, goal, and success criteria before touching anything</span></div>
          <div class="lpl"><strong>Build</strong><span>Execute against the plan; update the brief when the build teaches you something</span></div>
          <div class="lpl"><strong>Ship</strong><span>Put it in the world, in front of real people — not "ready to ship", shipped</span></div>
          <div class="lpl"><strong>Review</strong><span>Measure whether it worked; feed what you learned into the next cycle</span></div>
        </div>
      </div>

      <div class="hero-ctas">
        <a href="#examples" class="btn btn-primary">See it in action</a>
        <span class="btn btn-ghost btn-disabled">Read the docs <span class="cs-badge">coming soon</span></span>
      </div>
    </div>
  </section>

  <!-- ── Section 2: Why solveOS ───────────────────────── -->
  <section id="why" class="alt">
    <div class="container">
      <span class="label">Why solveOS</span>
      <h2 class="section-title">Most people fail at solving things for the same reasons.</h2>
      <p class="section-sub">You have probably experienced at least one of these.</p>

      <div class="grid-2 failure-grid">
        <div class="failure-card">
          <div class="failure-num">01</div>
          <h3>They skip planning.</h3>
          <p>They jump into execution without a clear goal and end up building the wrong thing. The work is real — the output isn't useful.</p>
        </div>
        <div class="failure-card">
          <div class="failure-num">02</div>
          <h3>They over-plan.</h3>
          <p>They get stuck refining the plan and never ship anything real. Perfect plans that never touch the world produce nothing.</p>
        </div>
        <div class="failure-card">
          <div class="failure-num">03</div>
          <h3>They lose direction.</h3>
          <p>The goal defined at the start gets distorted by the time execution ends. By the time it ships, nobody remembers what problem it was solving.</p>
        </div>
        <div class="failure-card">
          <div class="failure-num">04</div>
          <h3>They never measure.</h3>
          <p>They ship something, move on, and never find out if it worked. The same mistakes repeat in the next cycle, invisibly.</p>
        </div>
      </div>

      <p class="why-close">
        solveOS prevents all four — through structure, optional validation, a bias toward shipping, and a review loop that closes the cycle.
      </p>
    </div>
  </section>

  <!-- ── Section 3: Examples ──────────────────────────── -->
  <section id="examples">
    <div class="container">
      <span class="label">Worked examples</span>
      <h2 class="section-title">See it working end-to-end.</h2>
      <p class="section-sub">The fastest way to understand solveOS is to watch a full cycle from problem to shipped result.</p>

      <div class="grid-2">

        <div class="example-card card">
          <div class="card-label">Content</div>
          <h3>Writing a Technical Article</h3>
          <div class="cycle">
            <span class="gt">[Research]</span><span class="ar">→</span>
            <span class="ph">Plan</span><span class="ar">→</span>
            <span class="gt">[Plan Validation]</span><span class="ar">→</span>
            <span class="ph">Build</span><span class="ar">→</span>
            <span class="ph">Ship</span>
          </div>
          <p>A developer has a topic idea but isn't sure if the angle is useful. Research validates it, the plan is sharpened in one validation pass, and the article ships as a specific, actionable piece — not a vague tips list.</p>
          <blockquote class="key-moment">
            Plan Validation caught a weak argument before hours of writing.
          </blockquote>
          <span class="card-link card-link-disabled">Read the full example <span class="cs-badge">coming soon</span></span>
        </div>

        <div class="example-card card">
          <div class="card-label">Engineering</div>
          <h3>Building a Software Feature</h3>
          <div class="cycle">
            <span class="gt">[Research]</span><span class="ar">→</span>
            <span class="ph">Plan</span><span class="ar">→</span>
            <span class="gt">[Validation ×2]</span><span class="ar">→</span>
            <span class="ph">Build</span><span class="ar">→</span>
            <span class="gt">[Build Validation]</span><span class="ar">→</span>
            <span class="gt">[Review]</span><span class="ar">→</span>
            <span class="ph">Ship</span>
          </div>
          <p>The analytics dashboard loads in 8–12 seconds. Research identifies the root cause in 30 minutes. Two validation passes catch a vague success criterion. The fix ships — P95 load time drops from 9.2s to 0.9s.</p>
          <blockquote class="key-moment">
            Research redirected the entire approach — the obvious fix would have solved the wrong problem.
          </blockquote>
          <span class="card-link card-link-disabled">Read the full example <span class="cs-badge">coming soon</span></span>
        </div>

      </div>
    </div>
  </section>

  <!-- ── Section 4: Three Phases ──────────────────────── -->
  <section id="phases" class="alt">
    <div class="container">
      <span class="label">The framework</span>
      <h2 class="section-title">Three phases. Always in this order.</h2>
      <p class="section-sub">You plan before you build. You build before you ship. The loop closes when you review.</p>

      <div class="grid-3">
        {phases.map((phase, i) => (
          <div class="phase-card card">
            <div class="phase-number">{String(i + 1).padStart(2, '0')}</div>
            <h3>{phase.name}</h3>
            <p class="phase-desc">{phase.description}</p>
            <p class="phase-detail">{phase.detail}</p>
            <span class="card-link card-link-disabled">{phase.name} <span class="cs-badge">coming soon</span></span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── Section 5: Optional Gates ────────────────────── -->
  <section id="gates">
    <div class="container">
      <span class="label">Optional gates</span>
      <h2 class="section-title">Checkpoints between phases.</h2>
      <p class="section-sub">
        Gates are lightweight checkpoints you can insert between phases. Not mandatory — but skipping them has a cost. Use them when the stakes are high, the problem is ambiguous, or the build is complex.
      </p>

      <div class="full-cycle-wrap">
        <div class="full-cycle">
          <span class="gt">[Research]</span><span class="ar">→</span>
          <span class="ph">Plan</span><span class="ar">→</span>
          <span class="gt">[Plan Validation]</span><span class="ar">→</span>
          <span class="ph">Build</span><span class="ar">→</span>
          <span class="gt">[Build Validation]</span><span class="ar">→</span>
          <span class="gt">[Review]</span><span class="ar">→</span>
          <span class="ph">Ship</span><span class="ar">→</span>
          <span class="gt">[Review post-ship]</span>
        </div>
      </div>

      <div class="grid-2 gate-grid">
        {gates.map(gate => (
          <div class="card gate-card">
            <div class="gate-when">{gate.when}</div>
            <h3>[{gate.name}]</h3>
            <p>{gate.description}</p>
            <span class="card-link card-link-disabled">Read more <span class="cs-badge">coming soon</span></span>
          </div>
        ))}
      </div>

      <p class="gates-close">Gates serve the work. Skip them when the cost of being wrong is low. Use them when it isn't.</p>
    </div>
  </section>

  <!-- ── Section 6: solveOS and AI ────────────────────── -->
  <section id="ai" class="alt">
    <div class="container">
      <span class="label">AI-first design</span>
      <h2 class="section-title">solveOS is the first problem-solving framework designed around AI as primary executor.</h2>

      <div class="ai-lead">
        <p class="ai-tagline">AI executes. The human decides.</p>
        <p>
          Most frameworks were designed before AI could do meaningful work. They treat AI as an accelerator at best.
          solveOS is built from the ground up assuming AI can own the Build phase — and structures the collaboration
          so the work still gets done right.
        </p>
        <p>
          At every gate, the human reads the output and makes the call: proceed, iterate, or cut.
          AI does not decide what gets shipped. AI does not decide when the plan is correct.
          AI does not decide what success means. Those calls belong to the human at every step.
        </p>
      </div>

      <div class="table-wrap">
        <table class="data-table">
          <thead>
            <tr>
              <th>Phase / Gate</th>
              <th>AI can…</th>
              <th>Human must…</th>
            </tr>
          </thead>
          <tbody>
            {aiRows.map(row => (
              <tr>
                <td>{row.phase}</td>
                <td>{row.ai}</td>
                <td>{row.human}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      <div class="ref-files-note">
        <strong>Reference files.</strong> When AI builds, it needs two inputs: the Plan Brief (what to build)
        and reference files (the environment to build within — existing code, style guides, API specs, design files).
        A strong brief with no reference files produces well-intentioned but uninformed work.
        Reference files without a brief produce directionless work. Both are required.
      </div>
    </div>
  </section>

  <!-- ── Section 7: CLI ───────────────────────────────── -->
  <section id="cli">
    <div class="container cli-inner">
      <div class="cli-text">
        <span class="label">Tooling</span>
        <h2 class="section-title">A CLI for running solveOS end-to-end.</h2>
        <p class="cli-body">
          The framework works today with any editor and any AI tool.
          The CLI will make it faster — scaffolding Plan Briefs, managing reference files,
          running validation gates, and keeping the loop moving without switching contexts.
        </p>
        <ul class="cli-features">
          <li><span class="cli-feat-name">solveos init</span> — scaffold a new Plan Brief for any problem</li>
          <li><span class="cli-feat-name">solveos build</span> — run the Build phase with your AI of choice</li>
          <li><span class="cli-feat-name">solveos validate</span> — run a gate against the current output</li>
          <li><span class="cli-feat-name">solveos review</span> — close the loop after Ship</li>
        </ul>
        <span class="cs-pill">Coming soon</span>
      </div>
      <div class="cli-preview">
        <div class="cli-window">
          <div class="cli-window-bar">
            <span class="cli-dot"></span><span class="cli-dot"></span><span class="cli-dot"></span>
          </div>
          <div class="cli-body-code">
            <span class="cli-prompt">$</span> <span class="cli-cmd">solveos init</span><br/>
            <span class="cli-out">? What problem are you solving?</span><br/>
            <span class="cli-out">? Who is it for?</span><br/>
            <span class="cli-out">? What does success look like?</span><br/>
            <span class="cli-out cli-dim">→ plan-brief.md created</span><br/><br/>
            <span class="cli-prompt">$</span> <span class="cli-cmd">solveos validate --gate plan</span><br/>
            <span class="cli-out cli-dim">→ Checking brief against criteria...</span><br/>
            <span class="cli-out cli-warn">⚠ Core assumption not stated</span><br/>
            <span class="cli-out cli-warn">⚠ Success criteria is vague</span><br/>
            <span class="cli-out cli-dim">→ 2 issues found. Refine and re-run.</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Section 8: The Plan Brief ────────────────────── -->
  <section id="brief">
    <div class="container">
      <span class="label">The central artifact</span>
      <h2 class="section-title">The Plan Brief — the instruction set for everything.</h2>
      <p class="section-sub">
        The Plan Brief is the output of the Plan phase and the input to every other phase.
        When AI is building, the Plan Brief is its primary instruction.
        Every ambiguity in it becomes a guess in the output.
        Write it so that someone — or something — who didn't write it could execute it and produce the same result.
      </p>

      <div class="code-block">Problem          — What is broken, missing, or needed? Be specific.
Audience         — Who experiences this? Who will use what you build?
Goal             — What does success look like? One sentence, starts with a verb.
Appetite         — How much are you willing to invest? Scope fits inside this — not the other way around.
Constraints      — What are the non-negotiables beyond appetite?
Success criteria — How will you know this is done, objectively?
Core assumption  — What must be true for this plan to work? If this is false, the plan fails.
Rabbit holes     — What unknowns are you explicitly choosing not to explore in this cycle?
Out of scope     — What are you NOT solving?</div>

      <span class="btn btn-outline brief-link btn-disabled">Full template and guidance <span class="cs-badge">coming soon</span></span>
    </div>
  </section>

  <!-- ── Section 8: Five Principles ───────────────────── -->
  <section id="principles" class="alt">
    <div class="container">
      <span class="label">Philosophy</span>
      <h2 class="section-title">Five principles that govern how solveOS is applied.</h2>
      <p class="section-sub">Not rules. Lenses. When you feel stuck or off-track, return to them.</p>

      <div class="principles-list">
        {principles.map((p, i) => (
          <div class="principle-item">
            <div class="principle-num">{String(i + 1).padStart(2, '0')}</div>
            <div class="principle-body">
              <h3>{p.name}</h3>
              <p>{p.body}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── Section 9: Get Started ────────────────────────── -->
  <section id="start">
    <div class="container start-inner">
      <span class="label">Start here</span>
      <h2 class="section-title">Start using solveOS.</h2>
      <p class="start-sub">
        Open plan.md. Fill out the template for the problem you're working on right now. That's the starting point.
      </p>
      <span class="btn btn-primary btn-lg btn-disabled">Write your first Plan Brief <span class="cs-badge cs-badge-inv">coming soon</span></span>

      <div class="start-links">
        <span class="start-link-disabled">Framework overview <span class="cs-badge">coming soon</span></span>
        <span class="dot">·</span>
        <span class="start-link-disabled">Article example <span class="cs-badge">coming soon</span></span>
        <span class="dot">·</span>
        <span class="start-link-disabled">Engineering example <span class="cs-badge">coming soon</span></span>
      </div>

      <p class="start-close">The framework isn't complete until something is live.</p>
    </div>
  </section>

  <!-- ── Section 10: Email sign-up ─────────────────────── -->
  <section id="notify" class="alt">
    <div class="container notify-inner">
      <h2 class="notify-title">Get notified when docs and tools launch.</h2>
      <p class="notify-sub">No newsletter. One email when it's ready.</p>
      <form class="notify-form" onsubmit="return false;">
        <input
          type="email"
          class="notify-input"
          placeholder="your@email.com"
          aria-label="Email address"
          disabled
        />
        <button type="submit" class="btn btn-primary notify-btn btn-disabled" disabled>Notify me <span class="cs-badge cs-badge-inv">coming soon</span></button>
      </form>
      <p class="notify-note">Nothing ships until it's ready. That's the whole point.</p>
    </div>
  </section>

  <!-- ── Footer ────────────────────────────────────────── -->
  <footer>
    <div class="container footer-inner">
      <span class="footer-logo">solveOS</span>
      <span class="footer-tagline">A living framework. It improves through use.</span>
      <span class="footer-link footer-link-disabled">Full documentation <span class="cs-badge cs-badge-dark">coming soon</span></span>
    </div>
  </footer>

</Layout>

<style>
  /* ── Nav ─────────────────────────────── */
  nav {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(10, 10, 10, 0.95);
    backdrop-filter: blur(8px);
    border-bottom: 1px solid rgba(255,255,255,.08);
  }
  .nav-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    height: 3.25rem;
  }
  .nav-logo {
    font-size: 0.95rem;
    font-weight: 700;
    color: #fff;
    letter-spacing: -0.01em;
  }
  .nav-logo:hover { text-decoration: none; opacity: 0.8; }
  .nav-link {
    font-size: 0.85rem;
    color: rgba(255,255,255,.55);
    transition: color 0.15s;
  }
  .nav-link:hover { color: #fff; text-decoration: none; }

  /* ── Hero ───────────────────────────── */
  .hero {
    background: var(--bg-hero);
    color: var(--text-inv);
    padding: 6rem 0 5rem;
  }
  .hero-inner {
    max-width: 820px;
  }
  .hero-eyebrow {
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 1.25rem;
  }
  .hero-title {
    font-size: clamp(2.8rem, 6vw, 4.5rem);
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: -0.03em;
    color: #fff;
    margin-bottom: 1.25rem;
  }
  .hero-sub {
    font-size: 1.15rem;
    color: var(--text-inv-muted);
    max-width: 560px;
    line-height: 1.7;
    margin-bottom: 2.5rem;
  }

  /* Loop diagram */
  .loop-diagram {
    margin-bottom: 2.5rem;
    padding: 1.5rem 0;
    border-top: 1px solid rgba(255,255,255,.1);
    border-bottom: 1px solid rgba(255,255,255,.1);
  }
  .loop-main {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1.5rem;
    flex-wrap: wrap;
  }
  .loop-steps {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
    font-family: var(--font-mono);
    font-size: 1rem;
  }
  .lph { color: #60a5fa; font-weight: 700; }
  .lgt { color: #94a3b8; }
  .lar { color: rgba(255,255,255,.25); }
  .loop-arrow-left  { font-size: 1.2rem; color: rgba(255,255,255,.3); }
  .loop-arrow-right { font-size: 1.2rem; color: rgba(255,255,255,.3); }

  .loop-phase-labels {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
  }
  .lpl strong {
    display: block;
    font-size: 0.8rem;
    font-weight: 700;
    color: #fff;
    margin-bottom: 0.25rem;
  }
  .lpl span {
    font-size: 0.78rem;
    color: rgba(255,255,255,.45);
    line-height: 1.5;
  }

  .hero-ctas {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  /* ── Failure cards ──────────────────── */
  .failure-grid { margin-bottom: 2rem; }
  .failure-card {
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
